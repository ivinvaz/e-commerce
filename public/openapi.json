        "summary": "Adiciona um produto",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "NO_PRODUTO": {
                    "type": "string"
                  },
                  "ST_PRODUTO": {
                    "type": "integer"
