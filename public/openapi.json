              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Produto adicionado com sucesso."
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Lista um produto",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do produto"
          }
        ],
        "responses": {
          "200": {
            "description": "Produto retornado com sucesso."
          }
        }
      },
      "put": {
        "summary": "Atualiza um produto",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do produto a ser atualizado"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "NO_PRODUTO": {
                    "type": "string"
                  },
                  "ST_PRODUTO": {
                    "type": "integer"
                  }
                },
                "required": [
                  "NO_PRODUTO",
