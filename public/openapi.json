                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Produto atualizado com sucesso."
          }
        }
      },
      "delete": {
        "summary": "Deleta um produto",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do produto a ser deletado"
          }
        ],
        "responses": {
          "204": {
            "description": "Produto deletado com sucesso."
          }
        }
      }
    },
    "/products_cat": {
      "get": {
        "summary": "Lista todas as categorias de produtos",
