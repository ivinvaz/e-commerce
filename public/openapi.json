{
  "openapi": "3.0.0",
  "info": {
    "title": "API de E-commerce",
    "description": "Documentação da API REST para gerenciamento de um e-commerce, incluindo carrinho, produtos, usuários e estoque.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api"
    }
  ],
  "paths": {
    "/carrinho": {
      "post": {
        "summary": "Cria um novo carrinho",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "EMAIL_USUARIO": {
                    "type": "string",
                    "example": "usuario@email.com"
                  }
                },
                "required": [
                  "EMAIL_USUARIO"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Carrinho criado com sucesso."
          }
        }
      },
      "get": {
        "summary": "Lista todos os carrinhos",
        "responses": {
          "200": {
            "description": "Lista de carrinhos retornada com sucesso."
          }
        }
      }
    },
    "/carrinho/{id}": {
      "get": {
        "summary": "Lista um carrinho com seus itens",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do carrinho"
          }
        ],
        "responses": {
          "200": {
            "description": "Carrinho e itens retornados com sucesso."
          }
        }
      },
      "delete": {
        "summary": "Deleta um carrinho",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do carrinho a ser deletado"
          }
        ],
        "responses": {
          "204": {
            "description": "Carrinho deletado com sucesso."
          }
        }
      }
    },
    "/item": {
      "post": {
        "summary": "Adiciona um item ao carrinho",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "EMAIL_USUARIO": {
                    "type": "string",
                    "example": "usuario@email.com"
                  },
                  "SQ_PRODUTO": {
                    "type": "integer"
                  },
                  "SQ_TAMANHO_PRODUTO": {
                    "type": "integer"
                  },
                  "QTD_PRODUTO": {
                    "type": "integer"
                  }
                },
                "required": [
                  "EMAIL_USUARIO",
                  "SQ_PRODUTO",
                  "SQ_TAMANHO_PRODUTO",
                  "QTD_PRODUTO"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item adicionado ao carrinho com sucesso."
          }
        }
      }
    },
    "/item/{id}": {
      "put": {
        "summary": "Atualiza um item do carrinho",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do item a ser atualizado"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "SQ_PRODUTO": {
                    "type": "integer"
                  },
                  "SQ_TAMANHO_PRODUTO": {
                    "type": "integer"
                  },
                  "QTD_PRODUTO": {
                    "type": "integer"
                  }
                },
                "required": [
                  "SQ_PRODUTO",
                  "SQ_TAMANHO_PRODUTO",
                  "QTD_PRODUTO"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item do carrinho atualizado com sucesso."
          }
        }
      },
      "delete": {
        "summary": "Deleta um item do carrinho",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do item a ser deletado"
          }
        ],
        "responses": {
          "204": {
            "description": "Item do carrinho deletado com sucesso."
          }
        }
      }
    },
    "/login": {
      "post": {
        "summary": "Autentica um usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "EMAIL_USUARIO": {
                    "type": "string"
                  },
                  "SENHA_USUARIO": {
                    "type": "string"
                  }
                },
                "required": [
                  "EMAIL_USUARIO",
                  "SENHA_USUARIO"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso."
          },
          "401": {
            "description": "Credenciais inválidas."
          }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "Lista todos os produtos",
